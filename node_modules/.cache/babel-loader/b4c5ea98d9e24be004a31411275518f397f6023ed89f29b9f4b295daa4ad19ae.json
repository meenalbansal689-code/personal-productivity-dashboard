ktop/Personal Productivity Dashboard/productivity-dashboard/src/Notes.js"],"sourcesContent":["import { useState, useEffect } from \"react\";\r\nimport \"./Notes.css\";\r\n\r\nexport default function Notes() {\r\n  const [note, setNote] = useState(\"\");\r\n  const [notes, setNotes] = useState([]);\r\n  const [editId, setEditId] = useState(null);\r\n  const [habits, setHabits] = useState([]);\r\n\r\n  useEffect(() => {\r\n    const savedNotes = JSON.parse(localStorage.getItem(\"notes\"));\r\n    if (savedNotes) setNotes(savedNotes);\r\n  }, []);\r\n\r\n  useEffect(() => {\r\n    localStorage.setItem(\"notes\", JSON.stringify(notes));\r\n  }, [notes]);\r\n\r\n  const handleSubmit = () => {\r\n    if (note.trim() === \"\") return;\r\n\r\n    if (editId) {\r\n      setNotes(\r\n        notes.map((n) =>\r\n          n.id === editId ? { ...n, text: note } : n\r\n        )\r\n      );\r\n      setEditId(null);\r\n    } else {\r\n      setNotes([...notes, { id: Date.now(), text: note }]);\r\n    }\r\n\r\n    setNote(\"\");\r\n  };\r\n\r\n  const handleEdit = (n) => {\r\n    setNote(n.text);\r\n    setEditId(n.id);\r\n  };\r\n\r\n  const handleDelete = (id) => {\r\n    setNotes(notes.filter((n) => n.id !== id));\r\n  };\r\n\r\n  return (\r\n    <div className=\"notes-container\">\r\n      <h2>Notes</h2>\r\n\r\n      <input\r\n        type=\"text\"\r\n        placeholder=\"Write a note...\"\r\n        value={note}\r\n        onChange={(e) => setNote(e.target.value)}\r\n        className=\"note-input\"\r\n      />\r\n\r\n      <button onClick={handleSubmit} className=\"note-btn\">\r\n        {editId ? \"Update\" : \"Add\"}\r\n      </button>\r\n\r\n      <ul className=\"note-list\">\r\n        {notes.map((n) => (\r\n          <li key={n.id} className=\"note-item\">\r\n            <span>{n.text}</span>\r\n\r\n            <button onClick={() => handleEdit(n)}></button>\r\n            <button onClick={() => handleDelete(n.id)}></button>\r\n          </li>\r\n        ))}\r\n      </ul>\r\n    </div>\r\n  );\r\n}"],"mappings":"AAAA,OAASA,QAAQ,CAAEC,SAAS,KAAQ,OAAO,CAC3C,MAAO,aAAa,CAAC,OAAAC,GAAA,IAAAC,IAAA,CAAAC,IAAA,IAAAC,KAAA,yBAErB,cAAe,SAAS,CAAAC,KAAKA,CAAA,CAAG,CAC9B,KAAM,CAACC,IAAI,CAAEC,OAAO,CAAC,CAAGR,QAAQ,CAAC,EAAE,CAAC,CACpC,KAAM,CAACS,KAAK,CAAEC,QAAQ,CAAC,CAAGV,QAAQ,CAAC,EAAE,CAAC,CACtC,KAAM,CAACW,MAAM,CAAEC,SAAS,CAAC,CAAGZ,QAAQ,CAAC,IAAI,CAAC,CAC1C,KAAM,CAACa,MAAM,CAAEC,SAAS,CAAC,CAAGd,QAAQ,CAAC,EAAE,CAAC,CAExCC,SAAS,CAAC,IAAM,CACd,KAAM,CAAAc,UAAU,CAAGC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAAC,OAAO,CAAC,CAAC,CAC5D,GAAIJ,UAAU,CAAEL,QAAQ,CAACK,UAAU,CAAC,CACtC,CAAC,CAAE,EAAE,CAAC,CAENd,SAAS,CAAC,IAAM,CACdiB,YAAY,CAACE,OAAO,CAAC,OAAO,CAAEJ,IAAI,CAACK,SAAS,CAACZ,KAAK,CAAC,CAAC,CACtD,CAAC,CAAE,CAACA,KAAK,CAAC,CAAC,CAEX,KAAM,CAAAa,YAAY,CAAGA,CAAA,GAAM,CACzB,GAAIf,IAAI,CAACgB,IAAI,CAAC,CAAC,GAAK,EAAE,CAAE,OAExB,GAAIZ,MAAM,CAAE,CACVD,QAAQ,CACND,KAAK,CAACe,GAAG,CAAEC,CAAC,EACVA,CAAC,CAACC,EAAE,GAAKf,MAAM,CAAG,CAAE,GAAGc,CAAC,CAAEE,IAAI,CAAEpB,IAAK,CAAC,CAAGkB,CAC3C,CACF,CAAC,CACDb,SAAS,CAAC,IAAI,CAAC,CACjB,CAAC,IAAM,CACLF,QAAQ,CAAC,CAAC,GAAGD,KAAK,CAAE,CAAEiB,EAAE,CAAEE,IAAI,CAACC,GAAG,CAAC,CAAC,CAAEF,IAAI,CAAEpB,IAAK,CAAC,CAAC,CAAC,CACtD,CAEAC,OAAO,CAAC,EAAE,CAAC,CACb,CAAC,CAED,KAAM,CAAAsB,UAAU,CAAIL,CAAC,EAAK,CACxBjB,OAAO,CAACiB,CAAC,CAACE,IAAI,CAAC,CACff,SAAS,CAACa,CAAC,CAACC,EAAE,CAAC,CACjB,CAAC,CAED,KAAM,CAAAK,YAAY,CAAIL,EAAE,EAAK,CAC3BhB,QAAQ,CAACD,KAAK,CAACuB,MAAM,CAAEP,CAAC,EAAKA,CAAC,CAACC,EAAE,GAAKA,EAAE,CAAC,CAAC,CAC5C,CAAC,CAED,mBACErB,KAAA,QAAK4B,SAAS,CAAC,iBAAiB,CAAAC,QAAA,eAC9B/B,IAAA,OAAA+B,QAAA,CAAI,OAAK,CAAI,CAAC,cAEd/B,IAAA,UACEgC,IAAI,CAAC,MAAM,CACXC,WAAW,CAAC,iBAAiB,CAC7BC,KAAK,CAAE9B,IAAK,CACZ+B,QAAQ,CAAGC,CAAC,EAAK/B,OAAO,CAAC+B,CAAC,CAACC,MAAM,CAACH,KAAK,CAAE,CACzCJ,SAAS,CAAC,YAAY,CACvB,CAAC,cAEF9B,IAAA,WAAQsC,OAAO,CAAEnB,YAAa,CAACW,SAAS,CAAC,UAAU,CAAAC,QAAA,CAChDvB,MAAM,CAAG,QAAQ,CAAG,KAAK,CACpB,CAAC,cAETR,IAAA,OAAI8B,SAAS,CAAC,WAAW,CAAAC,QAAA,CACtBzB,KAAK,CAACe,GAAG,CAAEC,CAAC,eACXpB,KAAA,OAAe4B,SAAS,CAAC,WAAW,CAA